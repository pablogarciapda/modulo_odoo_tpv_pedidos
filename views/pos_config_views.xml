<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- Herencia: pos.config → campos impresora      -->
    <!-- ============================================ -->

    <record id="tpv_pedido_pos_config_view_form" model="ir.ui.view">
        <field name="name">pos.config.form.inherit.tpv.pedido</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <!--
                Insertar configuración de impresora del obrador DESPUÉS del
                bloque IoT Box completo (no dentro de él, porque proxy_ip
                está dentro de un div invisible por defecto).
                Usamos ancestor::setting para salir del contenedor IoT Box
                y agregar un setting nuevo al mismo nivel.
            -->
            <xpath expr="//field[@name='proxy_ip']/ancestor::setting[1]" position="after">
                <setting string="Impresora Obrador">
                    <div class="content-group">
                        <div class="row">
                            <div class="col-lg-4 o_light_label">
                                <label for="tpv_pedido_printer_ip"/>
                            </div>
                            <div class="col-lg-8">
                                <field name="tpv_pedido_printer_ip"
                                    placeholder="192.168.1.100"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-4 o_light_label">
                                <label for="tpv_pedido_printer_port"/>
                            </div>
                            <div class="col-lg-8">
                                <field name="tpv_pedido_printer_port"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-4 o_light_label">
                                <label for="tpv_pedido_printer_type"/>
                            </div>
                            <div class="col-lg-8">
                                <field name="tpv_pedido_printer_type"
                                    widget="radio"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-4 o_light_label">
                                <label for="tpv_pedido_print_hour"/>
                            </div>
                            <div class="col-lg-8">
                                <field name="tpv_pedido_print_hour" widget="float"/>
                            </div>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>