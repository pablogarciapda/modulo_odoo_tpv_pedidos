<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- Menú Principal: Pedidos Obrador             -->
    <!-- ============================================ -->

    <!-- Menú raíz bajo Punto de Venta -->
    <menuitem id="menu_tpv_pedidos_root"
        name="Pedidos Obrador"
        parent="point_of_sale.menu_point_root"
        sequence="15"/>

    <!-- Submenú Pedidos -->
    <menuitem id="menu_tpv_pedidos_pedido"
        name="Pedidos"
        parent="menu_tpv_pedidos_root"
        action="tpv_pedido_action"
        sequence="10"/>

    <!-- Submenú Categorías de Notas -->
    <menuitem id="menu_tpv_pedidos_nota_categoria"
        name="Categorías de Notas"
        parent="menu_tpv_pedidos_root"
        action="tpv_nota_categoria_action"
        sequence="20"/>

    <!-- Acción URL para Informes Web (debe ir ANTES del menuitem) -->
    <record id="action_open_web_informes" model="ir.actions.act_url">
        <field name="name">Informes Pedidos</field>
        <field name="url">/tpv_pedidos/informes</field>
        <field name="target">new</field>
    </record>

    <!-- Submenú Informes Web -->
    <menuitem id="menu_tpv_pedidos_informes"
        name="Informes Pedidos"
        parent="menu_tpv_pedidos_root"
        action="action_open_web_informes"
        sequence="22"/>

    <!-- Action: Pedidos Web (sale.order con tipo_pedido_tag) -->
    <record id="action_tpv_web_orders" model="ir.actions.act_window">
        <field name="name">Pedidos Web</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('tipo_pedido_tag', '!=', False)]</field>
        <field name="context">{'search_default_tipo_pedido': 1}</field>
    </record>

    <!-- Submenú Pedidos Web -->
    <menuitem id="menu_tpv_pedidos_web"
        name="Pedidos Web"
        parent="menu_tpv_pedidos_root"
        action="action_tpv_web_orders"
        sequence="15"/>

    <!-- Submenú Configuración Obrador (usa server action para singleton) -->
    <menuitem id="menu_tpv_pedidos_config"
        name="Configuración Obrador"
        parent="menu_tpv_pedidos_root"
        action="action_open_tpv_pedido_config"
        sequence="25"
        groups="point_of_sale.group_pos_manager"/>
</odoo>