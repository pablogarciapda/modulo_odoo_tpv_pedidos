<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tpv_backup_file_view_tree" model="ir.ui.view">
        <field name="name">tpv.backup.file.tree</field>
        <field name="model">tpv.backup.file</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <button name="action_download_selected" string="Descargar seleccionados" type="object"
                        confirm="Los archivos seleccionados se descargarán en ZIP y se eliminarán del sistema. ¿Continuar?"/>
                <field name="name"/>
                <field name="date"/>
                <field name="date_pedido"/>
                <field name="filename"/>
            </list>
        </field>
    </record>

    <record id="tpv_backup_file_action" model="ir.actions.act_window">
        <field name="name">Backups de impresión</field>
        <field name="res_model">tpv.backup.file</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_tpv_backup_file" name="Backups de impresión"
              parent="tpv_pedidos.menu_tpv_pedidos_root"
              action="tpv_backup_file_action"
              groups="point_of_sale.group_pos_manager"
              sequence="50"/>
</odoo>
