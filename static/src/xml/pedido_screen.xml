<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="tpv_pedidos.PedidoScreen">
        <div class="pedido-screen d-flex flex-column h-100">
            <!-- Header -->
            <div class="pedido-header d-flex justify-content-between align-items-center px-3 py-2 bg-dark text-white">
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-light btn-lg fw-bold" t-on-click="goBack">
                        <i class="fa fa-arrow-left me-2"/>Volver
                    </button>
                    <button class="btn btn-outline-info btn-lg fw-bold text-white"
                        t-on-click="openPedidoList">
                        <i class="fa fa-list me-2"/>Revisar Pedidos
                    </button>
                </div>
                <h4 class="mb-0 text-white fw-bold">
                    <i class="fa fa-truck me-2 text-white"/>
                    <t t-if="isEditing">
                        Editando: <t t-esc="state.editingPedidoName"/>
                    </t>
                    <t t-else="">
                        Pedido a Obrador —
                        <t t-esc="posConfigName"/>
                    </t>
                </h4>
                <div></div>
            </div>

            <!-- Main content -->
            <div class="pedido-content d-flex flex-grow-1" style="overflow: hidden;">
                <!-- LEFT: Order panel -->
                <div class="pedido-order-panel d-flex flex-column bg-light" style="width: 350px; min-width: 350px; border-right: 2px solid #dee2e6;">
                    <div class="p-2 border-bottom bg-white">
                        <h5 class="mb-1">Pedido <span class="badge bg-primary" t-esc="totalLines"/></h5>
                    </div>
                    <div class="pedido-order-lines flex-grow-1 overflow-auto p-2">
                        <t t-if="state.lines.length === 0">
                            <div class="text-center text-muted p-4">
                                <i class="fa fa-shopping-basket fa-3x mb-2"/>
                                <p class="mb-0">Añade productos al pedido</p>
                            </div>
                        </t>
                        <t t-foreach="state.lines" t-as="line" t-key="line.id">
                            <div class="pedido-order-line border rounded mb-2 p-2 bg-white">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1 me-2">
                                        <div class="fw-bold small" t-esc="line.product_name"/>
                                        <div class="text-muted small">
                                            <span t-esc="line.qty"/> × <t t-esc="line.precio_unitario.toFixed(2)"/> €
                                            = <span t-esc="(line.precio_unitario * line.qty).toFixed(2)"/> €
                                        </div>
                                        <t t-if="line.nota_categoria_name">
                                            <span class="badge bg-info small" t-esc="line.nota_categoria_name"/>
                                        </t>
                                        <t t-if="line.nota_linea">
                                            <div class="text-muted small fst-italic border-start border-info ps-1 mt-1" t-esc="line.nota_linea"/>
                                        </t>
                                    </div>
                                    <div class="d-flex flex-column gap-1">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-secondary" t-on-click="() => this.updateQty(line.id, -1)">
                                                <i class="fa fa-minus"/>
                                            </button>
                                            <span class="btn btn-outline-secondary disabled fw-bold opacity-100" t-esc="line.qty"/>
                                            <button class="btn btn-outline-secondary" t-on-click="() => this.updateQty(line.id, 1)">
                                                <i class="fa fa-plus"/>
                                            </button>
                                        </div>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-warning" title="Añadir nota"
                                                t-on-click="() => this.openNotaPopup(line)">
                                                <i class="fa fa-sticky-note"/>
                                            </button>
                                            <button class="btn btn-outline-danger" title="Eliminar"
                                                t-on-click="() => this.removeLine(line.id)">
                                                <i class="fa fa-trash"/>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                    <!-- Action buttons -->
                    <div class="p-2 border-top bg-white">
                        <t t-if="isEditing">
                            <!-- Edit mode buttons -->
                            <div class="mb-2">
                                <label class="form-label fw-bold small">Fecha de entrega</label>
                                <input type="date" class="form-control"
                                    t-model="state.fecha_entrega"/>
                            </div>
                            <div class="mb-2">
                                <label class="form-label fw-bold small">Nota general</label>
                                <textarea class="form-control" rows="2"
                                    t-model="state.nota_general" placeholder="Nota general..."/>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-success flex-grow-1 fw-bold py-3"
                                    t-att-disabled="state.lines.length === 0 ? 'disabled' : undefined"
                                    t-on-click="updatePedido">
                                    <i class="fa fa-save me-2"/>Actualizar
                                </button>
                                <button class="btn btn-outline-danger fw-bold py-3"
                                    t-on-click="cancelPedido">
                                    <i class="fa fa-ban me-2"/>Cancelar Pedido
                                </button>
                                <button class="btn btn-outline-secondary py-3"
                                    t-on-click="cancelEditing">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                        </t>
                        <t t-else="">
                            <!-- Create mode buttons -->
                            <t t-if="state.lines.length > 0">
                                <div class="mb-2">
                                    <label class="form-label fw-bold small">Fecha de entrega</label>
                                    <input type="date" class="form-control"
                                        t-model="state.fecha_entrega"/>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label fw-bold small">Nota general</label>
                                    <textarea class="form-control" rows="2"
                                        t-model="state.nota_general" placeholder="Nota general..."/>
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-warning flex-grow-1 fw-bold py-3"
                                        t-on-click="() => this.openConfirmPopup('encargo')">
                                        <i class="fa fa-star me-2"/>ENCARGO
                                    </button>
                                    <button class="btn btn-primary flex-grow-1 fw-bold py-3"
                                        t-on-click="() => this.openConfirmPopup('pedido_tienda')">
                                        <i class="fa fa-truck me-2"/>PEDIDO TIENDA
                                    </button>
                                </div>
                            </t>
                            <t t-else="">
                                <button class="btn btn-secondary w-100 py-2" disabled="disabled">
                                    <i class="fa fa-shopping-cart me-2"/>Añade productos para continuar
                                </button>
                            </t>
                        </t>
                    </div>
                </div>

                <!-- RIGHT: Categories + Products -->
                <div class="flex-grow-1 d-flex flex-column" style="overflow: hidden;">
                    <!-- Search bar -->
                    <div class="p-2 border-bottom bg-white">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fa fa-search"/></span>
                            <input type="text" class="form-control form-control-lg"
                                placeholder="Buscar producto..." t-model="state.searchText"/>
                        </div>
                    </div>
                    <!-- Category chips (hierarchical, touch-optimized) -->
                    <div class="pedido-categories p-2 border-bottom bg-light">
                        <button class="btn btn-sm me-1"
                            t-att-class="!state.selectedCategoryId ? 'btn-dark' : 'btn-outline-secondary'"
                            t-on-click="() => this.selectCategory(null)">
                            Todos
                        </button>
                        <t t-foreach="visibleCategories" t-as="cat" t-key="cat.id">
                            <button class="btn btn-sm me-1 btn-cat"
                                t-att-class="'o_tpv_color_' + (cat.color !== undefined ? cat.color : 11) + ' ' + (isCategorySelected(cat.id) ? 'btn-dark' : (isCategoryAncestor(cat.id) ? 'btn-primary' : 'btn-outline-secondary'))"
                                t-on-click="() => this.selectCategory(cat.id)">
                                <span class="cat-color-bar"
                                    t-att-class="'o_tpv_color_' + (cat.color !== undefined ? cat.color : 11)"/>
                                <span t-esc="cat.name"/>
                                <t t-if="isCategorySelected(cat.id) and getCategoryChildren(cat.id).length > 0">
                                    <i class="fa fa-chevron-down ms-1"/>
                                </t>
                            </button>
                        </t>
                        <t t-if="visibleCategories.length === 0">
                            <span class="text-muted small ms-2">Cargando categorías...</span>
                        </t>
                    </div>
                    <!-- Products grid -->
                    <div class="pedido-products flex-grow-1 p-2 overflow-auto">
                        <t t-if="products.length === 0">
                            <div class="text-center text-muted p-5">
                                <i class="fa fa-box-open fa-4x mb-3"/>
                                <p>No se encontraron productos</p>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="row g-2">
                                <t t-foreach="products" t-as="p" t-key="p.id">
                                    <div class="col-4 col-md-3 col-xl-2">
                                        <div class="card pedido-product-card h-100"
                                            t-on-click="() => this.onProductClick(p)">
                                            <div class="pedido-product-img-container d-flex align-items-center justify-content-center bg-light">
                                                <t t-if="this.getProductImageUrl(p)">
                                                    <img t-att-src="this.getProductImageUrl(p)"
                                                        class="img-fluid" alt="" draggable="false"/>
                                                </t>
                                                <t t-else="">
                                                    <i class="fa fa-box fa-3x text-muted"/>
                                                </t>
                                            </div>
                                            <div class="card-body p-1 text-center">
                                                <div class="product-name fw-bold" t-esc="p.display_name"/>
                                                <div class="cat-color-strip"
                                                    t-att-class="'o_tpv_color_' + this.getProductColor(p)"/>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- ============================================================ -->
    <!-- PedidoListPopup -->
    <!-- ============================================================ -->
    <t t-name="tpv_pedidos.PedidoListPopup">
        <Dialog size="'lg'">
            <t t-set-slot="header">
                <h4 class="modal-title"><i class="fa fa-list me-2"/>Pedidos del día</h4>
            </t>
            <div>
                <t t-if="props.pedidos.length === 0">
                    <p class="text-muted text-center p-4">No hay pedidos para hoy</p>
                </t>
                <t t-else="">
                    <div class="list-group" style="max-height: 400px; overflow-y: auto;">
                        <t t-foreach="props.pedidos" t-as="p" t-key="p.id">
                            <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-start"
                                t-on-click="() => this.selectPedido(p)">
                                <div>
                                    <div class="fw-bold">
                                        <span t-esc="p.name"/>
                                        <span class="badge ms-2"
                                            t-att-class="p.tipo_pedido === 'encargo' ? 'bg-warning text-dark' : 'bg-primary'"
                                            t-esc="p.tipo_pedido === 'encargo' ? 'ENCARGO' : 'TIENDA'"/>
                                    </div>
                                    <div class="small text-muted">
                                        <t t-esc="p.line_ids.length"/> líneas
                                        <t t-if="p.nota_general">
                                            — <span t-esc="p.nota_general"/>
                                        </t>
                                    </div>
                                </div>
                                <span class="badge"
                                    t-att-class="p.state === 'confirmed' ? 'bg-success' : 'bg-secondary'"
                                    t-esc="p.state"/>
                            </button>
                        </t>
                    </div>
                </t>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="cancel">Cerrar</button>
            </t>
        </Dialog>
    </t>
</templates>