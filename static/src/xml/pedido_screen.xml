<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="tpv_pedidos.PedidoScreen">
        <div class="pedido-screen d-flex flex-column h-100">
            <!-- Header -->
            <div class="pedido-header d-flex justify-content-between align-items-center p-3 bg-dark text-white">
                <button class="btn btn-outline-light" t-on-click="goBack">
                    <i class="fa fa-arrow-left"/> Volver
                </button>
                <h2 class="mb-0">
                    <i class="fa fa-truck"/> Pedido a Obrador —
                    <span t-esc="posConfigName"/>
                </h2>
                <div></div>
            </div>

            <!-- Main content: Categories + Products -->
            <div class="pedido-content d-flex flex-grow-1" style="overflow: hidden;">
                <!-- Categories sidebar -->
                <div class="pedido-categories p-2 bg-light border-end" style="width: 280px; overflow-y: auto;">
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Buscar producto..."
                            t-model="state.searchText" t-on-input="updateSearch"/>
                    </div>
                    <button class="btn btn-outline-primary w-100 mb-2"
                        t-on-click="() => this.selectCategory(null)">
                        Todos
                    </button>
                    <t t-foreach="categories" t-as="category" t-key="category.id">
                        <button class="btn w-100 mb-1 text-start"
                            t-att-class="state.selectedCategoryId === category.id ? 'btn-primary' : 'btn-outline-secondary'"
                            t-on-click="() => this.selectCategory(category.id)">
                            <span t-esc="category.name"/>
                        </button>
                    </t>
                </div>

                <!-- Products grid -->
                <div class="pedido-products flex-grow-1 p-3 overflow-auto">
                    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
                        <t t-foreach="products" t-as="product" t-key="product.id">
                            <div class="col">
                                <div class="card h-100 pedido-product-card"
                                    t-on-click="() => this.onProductClick(product)">
                                    <div class="card-body text-center p-2">
                                        <h6 class="card-title" t-esc="product.display_name"/>
                                        <small class="text-muted" t-esc="product.lst_price"/> €
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Order sidebar -->
                <div class="pedido-order-sidebar p-3 bg-light border-start" style="width: 320px; overflow-y: auto;">
                    <h5>Pedido (<span t-esc="totalLines"/>)</h5>
                    <!-- Order lines -->
                    <div class="pedido-order-lines">
                        <t t-if="state.lines.length === 0">
                            <div class="text-center text-muted p-4">
                                <i class="fa fa-shopping-basket fa-2x mb-2"/>
                                <p>Añade productos al pedido</p>
                            </div>
                        </t>
                        <t t-foreach="state.lines" t-as="line" t-key="line.id">
                            <div class="pedido-order-line d-flex align-items-center border rounded mb-2 p-2">
                                <div class="flex-grow-1">
                                    <div class="fw-bold" t-esc="line.product_name"/>
                                    <div class="text-muted small">
                                        <span t-esc="line.precio_unitario"/> € ×
                                        <span t-esc="line.qty"/>
                                    </div>
                                    <t t-if="line.nota_categoria_name">
                                        <span class="badge bg-info me-1" t-esc="line.nota_categoria_name"/>
                                    </t>
                                    <t t-if="line.nota_linea">
                                        <div class="text-muted small fst-italic" t-esc="line.nota_linea"/>
                                    </t>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <button class="btn btn-outline-secondary btn-sm"
                                        t-on-click="() => this.updateQty(line.id, -1)">
                                        <i class="fa fa-minus"/>
                                    </button>
                                    <span class="fw-bold" t-esc="line.qty"/>
                                    <button class="btn btn-outline-secondary btn-sm"
                                        t-on-click="() => this.updateQty(line.id, 1)">
                                        <i class="fa fa-plus"/>
                                    </button>
                                    <button class="btn btn-outline-warning btn-sm"
                                        t-on-click="() => this.openNotaPopup(line)">
                                        <i class="fa fa-sticky-note"/>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm"
                                        t-on-click="() => this.removeLine(line.id)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </div>
                            </div>
                        </t>
                    </div>
                    <!-- Action Buttons -->
                    <PedidoActionButtons
                        lines="state.lines"
                        linesToJSON="linesToJSON"
                        posConfigId="posConfigId"
                        posConfigName="posConfigName"
                        onClear="() => this.clearOrder()"/>
                </div>
            </div>
        </div>
    </t>
</templates>