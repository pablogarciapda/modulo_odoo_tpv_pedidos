<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="tpv_pedidos.PedidoActionButtons">
        <div class="pedido-action-buttons d-flex gap-2 mt-3">
            <button class="btn btn-warning flex-grow-1 fw-bold py-3"
                t-on-click="onClickEncargo"
                t-att-disabled="!this.hasLines ? 'disabled' : undefined">
                <i class="fa fa-star me-2"/>ENCARGO
            </button>
            <button class="btn btn-primary flex-grow-1 fw-bold py-3"
                t-on-click="onClickPedidoTienda"
                t-att-disabled="!this.hasLines ? 'disabled' : undefined">
                <i class="fa fa-truck me-2"/>PEDIDO TIENDA
            </button>
        </div>
    </t>
</templates>