<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="tpv_pedidos.PedidoOrder">
        <div class="pedido-order-lines">
            <t t-if="props.pedidoOrder.state.lines.length === 0">
                <div class="text-center text-muted p-4">
                    <i class="fa fa-shopping-basket fa-2x mb-2"/>
                    <p>Añade productos al pedido</p>
                </div>
            </t>
            <t t-foreach="props.pedidoOrder.state.lines" t-as="line" t-key="line.id">
                <div class="pedido-order-line d-flex align-items-center border rounded mb-2 p-2">
                    <div class="flex-grow-1">
                        <div class="fw-bold" t-esc="line.product_name"/>
                        <div class="text-muted small">
                            <span t-esc="line.precio_unitario"/> € ×
                            <span t-esc="line.qty"/>
                        </div>
                        <t t-if="line.nota_categoria_name">
                            <span class="badge bg-info me-1" t-esc="line.nota_categoria_name"/>
                        </t>
                        <t t-if="line.nota_linea">
                            <div class="text-muted small fst-italic" t-esc="line.nota_linea"/>
                        </t>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <button class="btn btn-outline-secondary btn-sm"
                            t-on-click="() => props.pedidoOrder.updateQty(line.id, line.qty - 1)">
                            <i class="fa fa-minus"/>
                        </button>
                        <span class="fw-bold" t-esc="line.qty"/>
                        <button class="btn btn-outline-secondary btn-sm"
                            t-on-click="() => props.pedidoOrder.updateQty(line.id, line.qty + 1)">
                            <i class="fa fa-plus"/>
                        </button>
                        <button class="btn btn-outline-warning btn-sm"
                            t-on-click="() => this.trigger('open-nota-popup', { lineId: line.id })">
                            <i class="fa fa-sticky-note"/>
                        </button>
                        <button class="btn btn-outline-danger btn-sm"
                            t-on-click="() => props.pedidoOrder.removeLine(line.id)">
                            <i class="fa fa-trash"/>
                        </button>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>