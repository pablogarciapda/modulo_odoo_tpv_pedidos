<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Impresión automática del resumen de pedidos a las 02:00 -->
        <record id="cron_tpv_pedido_imprimir_resumen" model="ir.cron">
            <field name="name">TPV Pedidos: Imprimir resumen diario del obrador</field>
            <field name="model_id" ref="model_tpv_pedido"/>
            <field name="state">code</field>
            <field name="code">model._cron_imprimir_resumen_obrador()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="hour">2</field>
            <field name="minute">0</field>
        </record>
    </data>
</odoo>