<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_pedido_obrador" model="ir.actions.report">
        <field name="name">Resumen Pedidos Obrador</field>
        <field name="model">tpv.pedido</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tpv_pedidos.report_pedido_obrador</field>
        <field name="report_file">tpv_pedidos.report_pedido_obrador</field>
        <field name="print_report_name">'Resumen_Pedidos_Obrador_%s' % (object.date_pedido)</field>
        <field name="binding_model_id" ref="model_tpv_pedido"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="tpv_pedidos.paperformat_obrador_horizontal"/>
    </record>

    <template id="report_pedido_obrador">
        <main>
            <t t-set="o" t-value="docs"/>
            <div class="page">
                <!-- PORTADA -->
                <div class="text-center mb-4" style="padding-top: 100px;">
                    <h1>Resumen de Pedidos del Obrador</h1>
                    <h3 t-esc="data['fecha']" t-options="{'widget': 'date'}"/>
                </div>
                <div class="text-center">
                    <p>Documento generado automaticamente</p>
                </div>
            </div>

            <!-- Bloque 1: Totales por familia -->
            <t t-foreach="data['bloque1']" t-as="cat_id">
                <t t-set="cat_data" t-value="data['bloque1'][cat_id]"/>
                <t t-foreach="range(cat_data['copies'])" t-as="copy_num">
                    <div class="page">
                        <h2 style="font-size:16px; margin-bottom:4px;">
                            INFORME FABRICACION - <t t-esc="data['fecha']" t-options="{'widget': 'date'}"/>
                        </h2>
                        <h3 style="font-size:14px; margin:4px 0;">
                            <t t-esc="cat_data['name']"/>
                            <span style="font-size:10px; color:#999;">(Copia <t t-esc="copy_num + 1"/>)</span>
                        </h3>
                        <t t-if="cat_data['products']">
                            <table style="width:100%; border-collapse:collapse; font-size:11px;">
                                <thead>
                                    <tr style="border-bottom:2px solid #000;">
                                        <th style="text-align:left; padding:2px 4px;">Producto</th>
                                        <th style="text-align:right; padding:2px 4px;">Total</th>
                                        <th style="text-align:right; padding:2px 4px;">Ext</th>
                                        <t t-foreach="cat_data['products'][0]['tiendas']" t-as="tienda_nombre">
                                            <th style="text-align:right; padding:2px 4px;" t-esc="tienda_nombre"/>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="cat_data['products']" t-as="prod">
                                        <tr style="border-bottom:1px dotted #ccc;">
                                            <td style="padding:1px 4px;" t-esc="prod['name']"/>
                                            <td style="text-align:right; padding:1px 4px;" t-esc="int(prod['total'])"/>
                                            <td style="text-align:right; padding:1px 4px;" t-esc="int(prod['exterior'])"/>
                                            <t t-foreach="prod['tiendas']" t-as="tienda_nombre" t-key="tienda_nombre_index">
                                                <td style="text-align:right; padding:1px 4px;" t-esc="int(prod['tiendas'][tienda_nombre])"/>
                                            </t>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <p style="color:#999;">Sin productos en esta categoria.</p>
                        </t>
                    </div>
                </t>
            </t>

            <!-- Bloque 2: Clientes Externos -->
            <t t-if="data['bloque2']">
                <t t-foreach="data['bloque2']" t-as="cliente">
                    <div class="page">
                        <h3>Cliente: <span t-esc="cliente['name']"/></h3>
                        <div class="mb-3">
                            <p>Telefono: <t t-esc="cliente['phone']"/></p>
                            <p>Direccion: <t t-esc="cliente['address']"/></p>
                            <p>Entrega: <t t-esc="cliente['delivery']"/></p>
                            <p>Total: <t t-esc="cliente['total_amount']"/> €</p>
                        </div>
                        <table class="table table-sm">
                            <thead><tr><th>Producto</th><th class="text-end">Cantidad</th></tr></thead>
                            <tbody>
                                <t t-foreach="cliente['products']" t-as="prod">
                                    <tr>
                                        <td t-esc="prod['name']"/>
                                        <td class="text-end" t-esc="int(prod['qty'])"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>

            <!-- Bloque 3 -> Modulo 2: Encargos de Tiendas -->
            <t t-if="data.get('module2_title') and data['bloque3']">
                <div class="page">
                    <h1 class="text-center mb-4" t-esc="data['module2_title']"/>
                </div>
            </t>
            <t t-if="data['bloque3']">
                <t t-foreach="data['bloque3']" t-as="tienda_name">
                    <div class="page" style="font-size:11px;">
                        <h3 style="font-size:14px; margin:4px 0; border-bottom:1px solid #000; padding-bottom:2px;">
                            --- <t t-esc="tienda_name"/> ---
                        </h3>
                        <h4 style="font-size:12px; margin:4px 0 2px 0;">ENCARGOS</h4>
                        <t t-foreach="data['bloque3'][tienda_name]" t-as="enc">
                            <div style="margin:2px 0; padding:2px 0; border-bottom:1px dotted #ccc;">
                                <strong style="font-size:11px;" t-esc="enc['name']"/>
                                <t t-if="enc['nota']">
                                    <span style="color:#666; font-style:italic; font-size:9px; margin-left:8px;" t-esc="enc['nota']"/>
                                </t>
                                <table style="width:100%; border-collapse:collapse; font-size:9px;">
                                    <t t-foreach="enc['lines']" t-as="l">
                                        <tr>
                                            <td style="padding:1px 2px;" t-esc="l['name']"/>
                                            <td style="text-align:right; padding:1px 2px; white-space:nowrap;">
                                                <t t-esc="int(l['qty'])"/> uds
                                            </td>
                                            <t t-if="l['nota']">
                                                <td style="padding:1px 2px; color:#666; font-size:8px; text-align:right;" t-esc="l['nota']"/>
                                            </t>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                        </t>
                    </div>
                </t>
            </t>

            <!-- Bloque 4 -> Modulo 4: Encargos Especificos -->
            <t t-if="data.get('module4_title') and data['bloque4']">
                <div class="page">
                    <h1 class="text-center mb-4" t-esc="data['module4_title']"/>
                </div>
            </t>
            <t t-if="data['bloque4']">
                <t t-foreach="data['bloque4']" t-as="tienda_name">
                    <div class="page" style="font-size:11px;">
                        <h3 style="font-size:14px; margin:4px 0; border-bottom:1px solid #000; padding-bottom:2px;">
                            --- <t t-esc="tienda_name"/> ---
                        </h3>
                        <h4 style="font-size:12px; margin:4px 0 2px 0;">ENCARGOS ESPECIFICOS</h4>
                        <t t-foreach="data['bloque4'][tienda_name]" t-as="enc">
                            <div style="margin:2px 0; padding:2px 0; border-bottom:1px dotted #ccc;">
                                <strong style="font-size:11px;" t-esc="enc['name']"/>
                                <t t-if="enc['nota']">
                                    <span style="color:#666; font-style:italic; font-size:9px; margin-left:8px;" t-esc="enc['nota']"/>
                                </t>
                                <table style="width:100%; border-collapse:collapse; font-size:9px;">
                                    <t t-foreach="enc['lines']" t-as="l">
                                        <tr>
                                            <td style="padding:1px 2px;" t-esc="l['name']"/>
                                            <td style="text-align:right; padding:1px 2px; white-space:nowrap;">
                                                <t t-esc="int(l['qty'])"/> uds
                                            </td>
                                            <t t-if="l['nota']">
                                                <td style="padding:1px 2px; color:#666; font-size:8px; text-align:right;" t-esc="l['nota']"/>
                                            </t>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                        </t>
                    </div>
                </t>
            </t>

            <!-- Bloque 5: Pedidos Personalizados -->
            <t t-if="data.get('module5_title') and data['bloque5']">
                <div class="page">
                    <h1 class="text-center mb-4" t-esc="data['module5_title']"/>
                </div>
            </t>
            <t t-if="data['bloque5']">
                <t t-foreach="data['bloque5']" t-as="pedido">
                    <div class="page">
                        <h3><t t-esc="pedido['name']"/></h3>
                        <div class="mb-3">
                            <p>Origen: <t t-esc="pedido['origen']"/></p>
                            <p>Tienda: <t t-esc="pedido['tienda']"/></p>
                            <t t-if="pedido['nota']">
                                <p class="text-muted fst-italic" t-esc="pedido['nota']"/>
                            </t>
                        </div>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-end">Cantidad</th>
                                    <th>Nota</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="pedido['lines']" t-as="l">
                                    <tr>
                                        <td t-esc="l['name']"/>
                                        <td class="text-end" t-esc="int(l['qty'])"/>
                                        <td><t t-if="l['nota']" t-esc="l['nota']"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </main>
    </template>
</odoo>
