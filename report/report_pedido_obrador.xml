<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_pedido_obrador" model="ir.actions.report">
        <field name="name">Resumen Pedidos Obrador</field>
        <field name="model">tpv.pedido</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tpv_pedidos.report_pedido_obrador</field>
        <field name="report_file">tpv_pedidos.report_pedido_obrador</field>
        <field name="print_report_name">'Resumen_Pedidos_Obrador_%s' % (object.date_pedido)</field>
        <field name="binding_model_id" ref="model_tpv_pedido"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pedido_obrador">
        <main>
            <t t-set="o" t-value="docs"/>
            <div class="page">
                <!-- PORTADA -->
                <div class="text-center mb-4" style="padding-top: 100px;">
                    <h1>Resumen de Pedidos del Obrador</h1>
                    <h3 t-esc="data['fecha']" t-options="{'widget': 'date'}"/>
                </div>
                <div class="text-center">
                    <p>Documento generado automaticamente</p>
                </div>
            </div>

            <!-- Bloque 1: Totales por familia -->
            <t t-if="data.get('module1_title')">
                <div class="page">
                    <h1 class="text-center mb-4" t-esc="data['module1_title']"/>
                    <p class="text-muted text-center">Resumen de produccion del obrador</p>
                </div>
            </t>
            <t t-foreach="data['bloque1']" t-as="cat_id">
                <t t-set="cat_data" t-value="data['bloque1'][cat_id]"/>
                <!-- Print cat_data['copies'] copies -->
                <t t-foreach="range(cat_data['copies'])" t-as="copy_num">
                    <div class="page">
                        <h2 class="text-center mb-4">
                            <t t-esc="cat_data['name']"/>
                            <span class="small text-muted">(Copia <t t-esc="copy_num + 1"/>)</span>
                        </h2>

                        <t t-if="cat_data['products']">
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>Producto</th>
                                        <th class="text-end">Total</th>
                                        <th class="text-end">Exterior</th>
                                        <t t-foreach="cat_data['products'][0]['tiendas']" t-as="tienda_nombre">
                                            <th class="text-end" t-esc="tienda_nombre"/>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="cat_data['products']" t-as="prod">
                                        <tr>
                                            <td t-esc="prod['name']"/>
                                            <td class="text-end" t-esc="prod['total']"/>
                                            <td class="text-end" t-esc="prod['exterior']"/>
                                            <t t-foreach="prod['tiendas']" t-as="tienda_nombre" t-key="tienda_nombre_index">
                                                <td class="text-end" t-esc="prod['tiendas'][tienda_nombre]"/>
                                            </t>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <p class="text-muted">No hay productos en esta categoria.</p>
                        </t>
                    </div>
                </t>
            </t>

            <!-- Bloque 2: Clientes Externos -->
            <t t-if="data['bloque2']">
                <t t-foreach="data['bloque2']" t-as="cliente">
                    <div class="page">
                        <h3>Cliente: <span t-esc="cliente['name']"/></h3>
                        <div class="mb-3">
                            <p>Telefono: <t t-esc="cliente['phone']"/></p>
                            <p>Direccion: <t t-esc="cliente['address']"/></p>
                            <p>Entrega: <t t-esc="cliente['delivery']"/></p>
                            <p>Total: <t t-esc="cliente['total_amount']"/> €</p>
                        </div>
                        <table class="table table-sm">
                            <thead><tr><th>Producto</th><th class="text-end">Cantidad</th></tr></thead>
                            <tbody>
                                <t t-foreach="cliente['products']" t-as="prod">
                                    <tr>
                                        <td t-esc="prod['name']"/>
                                        <td class="text-end" t-esc="prod['qty']"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>

            <!-- Bloque 3 -> Modulo 2: Encargos de Tiendas -->
            <t t-if="data.get('module2_title') and data['bloque3']">
                <div class="page">
                    <h1 class="text-center mb-4" t-esc="data['module2_title']"/>
                </div>
            </t>
            <t t-if="data['bloque3']">
                <t t-foreach="data['bloque3']" t-as="tienda_name">
                    <div class="page">
                        <h3>--- <t t-esc="tienda_name"/> ---</h3>
                        <h4>ENCARGOS</h4>
                        <t t-foreach="data['bloque3'][tienda_name]" t-as="enc">
                            <div class="border rounded mb-3 p-2">
                                <strong t-esc="enc['name']"/>
                                <t t-if="enc['nota']">
                                    <p class="text-muted fst-italic" t-esc="enc['nota']"/>
                                </t>
                                <ul>
                                    <t t-foreach="enc['lines']" t-as="l">
                                        <li>
                                            <t t-esc="l['name']"/> — <t t-esc="l['qty']"/> uds
                                            <t t-if="l['nota']">
                                                <span class="badge bg-info" t-esc="l['nota']"/>
                                            </t>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </t>
                    </div>
                </t>
            </t>

            <!-- Bloque 4 -> Modulo 4: Encargos Especificos -->
            <t t-if="data.get('module4_title') and data['bloque4']">
                <div class="page">
                    <h1 class="text-center mb-4" t-esc="data['module4_title']"/>
                </div>
            </t>
            <t t-if="data['bloque4']">
                <t t-foreach="data['bloque4']" t-as="tienda_name">
                    <div class="page">
                        <h3>--- <t t-esc="tienda_name"/> ---</h3>
                        <h4>ENCARGOS ESPECIFICOS</h4>
                        <t t-foreach="data['bloque4'][tienda_name]" t-as="enc">
                            <div class="border rounded mb-3 p-2">
                                <strong t-esc="enc['name']"/>
                                <t t-if="enc['nota']">
                                    <p class="text-muted fst-italic" t-esc="enc['nota']"/>
                                </t>
                                <ul>
                                    <t t-foreach="enc['lines']" t-as="l">
                                        <li>
                                            <t t-esc="l['name']"/> — <t t-esc="l['qty']"/> uds
                                            <t t-if="l['nota']">
                                                <span class="badge bg-info" t-esc="l['nota']"/>
                                            </t>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </t>
                    </div>
                </t>
            </t>

            <!-- Bloque 5: Pedidos Personalizados -->
            <t t-if="data.get('module5_title') and data['bloque5']">
                <div class="page">
                    <h1 class="text-center mb-4" t-esc="data['module5_title']"/>
                </div>
            </t>
            <t t-if="data['bloque5']">
                <t t-foreach="data['bloque5']" t-as="pedido">
                    <div class="page">
                        <h3><t t-esc="pedido['name']"/></h3>
                        <div class="mb-3">
                            <p>Origen: <t t-esc="pedido['origen']"/></p>
                            <p>Tienda: <t t-esc="pedido['tienda']"/></p>
                            <t t-if="pedido['nota']">
                                <p class="text-muted fst-italic" t-esc="pedido['nota']"/>
                            </t>
                        </div>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-end">Cantidad</th>
                                    <th>Nota</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="pedido['lines']" t-as="l">
                                    <tr>
                                        <td t-esc="l['name']"/>
                                        <td class="text-end" t-esc="l['qty']"/>
                                        <td><t t-if="l['nota']" t-esc="l['nota']"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </main>
    </template>
</odoo>
